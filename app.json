{
  "expo": {
    "name": "Banglar Shiksha Assistant",
    "slug": "banglar-shiksha-assistant",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "banglarshikshaassistant",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sandip2025.bsassistant",
      "infoPlist": {
        "NSCameraUsageDescription": "This app uses camera to scan report cards and HPRC documents.",
        "NSPhotoLibraryUsageDescription": "This app needs access to photos to pick report card images from gallery."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1a73e8",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "package": "com.sandip2025.bsassistant",
      "permissions": [
        "android.permission.CAMERA",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ],
      "edgeToEdgeEnabled": true
    },
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 24,
            "compileSdkVersion": 35,
            "targetSdkVersion": 35
          }
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#1a73e8"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9f0f04bd-9acf-4de5-8457-53725c55458a"
      }
    }
  }
}
